erDiagram
    %% Original Network System Relationships
    User ||--o{ UserAccount : has
    User ||--o{ Session : has
    User ||--o{ RequestLog : has
    Account ||--o{ UserAccount : has
    Account ||--o{ Profile : has
    Account }|--|| Tenant : belongs_to
    Tenant ||--o{ AppInstance : installs
    Tenant ||--|{ Profile : has
    Tenant ||--|{ Listing : has
    Tenant ||--|{ Template : has
    AppInstance ||--|{ AppDomain : routes
    Profile ||--o{ Listing : creates
    Profile ||--o{ AdPurchase : makes
    Listing }|--|| Category : belongs_to
    Listing ||--o{ ListingAttribute : has
    Listing ||--o{ AdPurchase : has
    Template }|--|| Category : belongs_to
    Template }|--|| Category : belongs_to
    Template }|--|| Tenant : belongs_to
    Template ||--o{ ListingAttribute : has
    Category ||--o{ Category : has_subcategories

    %% Clipping Marketplace Relationships
    Tenant ||--o{ SocialChannel : has
    Tenant ||--o{ Campaign : hosts
    Campaign ||--o{ Asset : provides
    Campaign ||--o{ ClipSubmission : has
    SocialChannel ||--o{ ClipSubmission : submits
    ClipSubmission ||--o{ MetricHistory : logs
    
    %% Branded Client Delivery Relationships
    Tenant ||--o{ DeliveryPortal : manages
    DeliveryPortal ||--o{ DeliverySession : tracks
    DeliverySession ||--o{ DeliveryPaywall : secures
    
    %% Classified Directory Extensions
    Listing ||--o{ ListingBump : prioritizes
    Profile ||--o{ IdentityVerification : undergoes
    
    %% Property Management Relationships
    Tenant ||--o{ LandlordPortfolio : has
    LandlordPortfolio ||--o{ ManagedProperty : contains
    ManagedProperty ||--o{ LeaseContract : active_leases
    LeaseContract ||--o{ LateFeeSuppression : evaluates
    ManagedProperty ||--o{ MaintenanceTriage : triages
    
    %% Dynamic Packaging & Booking Relationships
    Tenant ||--o{ PackageTenant : contains
    PackageTenant ||--o{ AgencySeat : has
    PackageTenant ||--o{ PackageBooking : processes
    PackageBooking ||--o{ BookingItem : contains
    PackageBooking ||--o{ PriceLock : secures
    PackageBooking ||--o{ CommissionLedger : records
    
    %% STR Compliance Relationships
    Tenant ||--o{ ComplianceProperty : tracks
    ComplianceProperty ||--o{ PropertyPermit : requires
    ComplianceProperty ||--o{ TdtBookingReceipt : ingests
    ComplianceProperty ||--o{ TdtMonthlyReconciliation : files
    ComplianceProperty ||--o{ ActiveOtaListing : syncs
    ComplianceProperty ||--o{ ComplianceAlert : triggers
    
    %% Direct Booking & Comms Relationships
    Tenant ||--o{ BookingTenant : configures
    BookingTenant ||--o{ HotelRoomType : defines
    HotelRoomType ||--o{ RoomRate : sets
    BookingTenant ||--o{ CorporateContract : negotiates
    BookingTenant ||--o{ DirectBooking : processes
    DirectBooking ||--o{ BookedPerk : assigns
    BookingTenant ||--o{ CartSession : tracks
    
    Tenant ||--o{ CommsTenant : manages
    CommsTenant ||--o{ GuestProfile : registers
    GuestProfile ||--o{ GuestReservation : books
    GuestReservation ||--o{ MessageLog : archives
    CommsTenant ||--o{ RecipientStaff : employs
    RecipientStaff ||--o{ WorkTask : performs
    CommsTenant ||--o{ LocalRecommendation : curates

    %% New CRM Relationships
    Customer ||--o{ Deal : has
    Customer ||--o{ Contact : has
    Customer ||--o{ Case : has
    Customer ||--o{ Activity : has
    Customer ||--o{ Note : has
    Deal ||--o{ DealContact : has
    Deal ||--o{ Activity : has
    Deal ||--o{ Note : has
    Contact ||--o{ DealContact : has
    Contact ||--o{ Activity : has
    Contact ||--o{ Note : has
    Lead ||--o{ Activity : has
    Lead ||--o{ Note : has
    Case ||--o{ Activity : has
    Case ||--o{ Note : has
    Activity ||--o{ Note : has
    FileAssociation }|--|| File : belongs_to

    %% File Associations
    Customer ||--o{ FileAssociation : has
    Deal ||--o{ FileAssociation : has
    Contact ||--o{ FileAssociation : has
    Lead ||--o{ FileAssociation : has
    Case ||--o{ FileAssociation : has
    Activity ||--o{ FileAssociation : has
    Note ||--o{ FileAssociation : has

    User {
        UUID id PK
        string username
        string email
        string password_hash
        boolean is_admin
        boolean is_active
        datetime created_at
        datetime updated_at
    }

    Account {
        UUID id PK
        UUID tenant_id FK
        string name
        boolean is_active
        datetime created_at
        datetime updated_at
    }

    UserAccount {
        UUID id PK
        UUID user_id FK
        UUID account_id FK
        string role
        boolean is_active
        datetime created_at
        datetime updated_at
    }

    Profile {
        UUID id PK
        UUID account_id FK
        UUID tenant_id FK
        string profile_type
        string display_name
        string contact_info
        string business_name
        string business_address
        string business_phone
        string business_website
        json additional_info
        boolean is_active
        datetime created_at
        datetime updated_at
    }

    Tenant {
        UUID id PK
        string name
        string description
        string site_status
        json custom_settings
        datetime created_at
        datetime updated_at
    }

    AppInstance {
        UUID id PK
        UUID tenant_id FK
        string app_type
        string database_url
        json settings
        datetime created_at
        datetime updated_at
    }

    AppDomain {
        UUID id PK
        UUID app_instance_id FK
        string domain
        boolean is_primary
    }

    Listing {
        UUID id PK
        UUID profile_id FK
        UUID tenant_id FK
        UUID category_id FK
        UUID based_on_template_id FK
        string title
        string description
        string listing_type
        int64 price
        string price_type
        string country
        string state
        string city
        string neighborhood
        float latitude
        float longitude
        json additional_info
        string status
        boolean is_featured
        boolean is_based_on_template
        boolean is_ad_placement
        boolean is_active
        datetime created_at
        datetime updated_at
    }

    ListingAttribute {
        UUID id PK
        UUID listing_id FK
        UUID template_id FK
        string attribute_type
        string attribute_key
        json value
    }

    Category {
        UUID id PK
        UUID parent_category_id FK
        string name
        string description
        boolean is_custom
        boolean is_active
        datetime created_at
        datetime updated_at
    }

    Template {
        UUID id PK
        UUID tenant_id FK
        UUID category_id FK
        string name
        string description
        string template_type
        boolean is_active
        datetime created_at
        datetime updated_at
    }

    AdPurchase {
        UUID id PK
        UUID listing_id FK
        UUID profile_id FK
        datetime start_date
        datetime end_date
        float price
        string status
    }

    Session {
        UUID id PK
        UUID user_id FK
        string bearer_token_hash
        string refresh_token_hash
        datetime token_expiration
        boolean is_active
    }

    RequestLog {
        UUID id PK
        UUID user_id FK
        string ip_address
        string path
        string method
        int status_code
        string request_type
    }

    Customer {
        UUID id PK
        string name
        UUID primary_contact_id FK
        string customer_type
        json attributes
        string cpf
        string cnpj
        string tin
        string email
        string phone
        string whatsapp
        string telegram
        string twitter
        string instagram
        string facebook
        string website
        float annual_revenue
        int employee_count
        boolean is_active
        json billing_address
        json shipping_address
        datetime created_at
        datetime updated_at
    }

    Deal {
        UUID id PK
        UUID customer_id FK
        string name
        float amount
        string status
        string stage
        datetime close_date
        boolean is_active
        datetime created_at
        datetime updated_at
    }

    Contact {
        UUID id PK
        UUID customer_id FK
        string name
        string email
        string phone
        string role
        datetime created_at
        datetime updated_at
    }

    Lead {
        UUID id PK
        UUID associated_deal_id FK
        string name
        string email
        string phone
        string status
        boolean is_converted
        datetime created_at
        datetime updated_at
    }

    Case {
        UUID id PK
        UUID customer_id FK
        string title
        string description
        string status
        string priority
        UUID assigned_to FK
        datetime closed_at
        datetime created_at
        datetime updated_at
    }

    Activity {
        UUID id PK
        UUID account_id FK
        UUID deal_id FK
        UUID customer_id FK
        UUID lead_id FK
        UUID contact_id FK
        UUID case_id FK
        string activity_type
        string title
        string description
        string status
        datetime due_date
        datetime completed_at
        json associated_entities
        UUID created_by FK
        UUID assigned_to FK
        datetime created_at
        datetime updated_at
    }

    Note {
        UUID id PK
        string content
        UUID created_by FK
        string entity_type
        UUID entity_id
        datetime created_at
        datetime updated_at
    }

    File {
        UUID id PK
        string name
        string file_type
        string storage_path
        int64 size
        datetime created_at
        datetime updated_at
    }

    FileAssociation {
        UUID id PK
        UUID file_id FK
        string associated_entity_type
        UUID associated_entity_id
    }

    DealContact {
        UUID deal_id FK
        UUID contact_id FK
    }

    %% Clipping Marketplace Entities
    SocialChannel {
        UUID id PK
        UUID user_id FK
        string platform
        string platform_user_id
        string handle
        int follower_count
        boolean verified
    }
    Campaign {
        UUID id PK
        UUID creator_id FK
        string title
        string description
        string guidelines
        string hashtags
        int cpm_cents
        int min_views_threshold
        int64 escrow_budget_cents
        int64 remaining_budget_cents
        string status
        datetime starts_at
        datetime ends_at
    }
    Asset {
        UUID id PK
        UUID campaign_id FK
        string name
        string source_url
        int duration_seconds
    }
    ClipSubmission {
        UUID id PK
        UUID campaign_id FK
        UUID clipper_id FK
        UUID channel_id FK
        string video_url
        string external_video_id
        string video_hash
        string status
        int cumulative_views
        int64 payout_cents_earned
    }
    MetricHistory {
        UUID id PK
        UUID submission_id FK
        int views
        int likes
        int comments
        int shares
        datetime sampled_at
    }

    %% Branded Client Delivery Entities
    DeliveryPortal {
        UUID id PK
        UUID tenant_id FK
        string subdomain
        string domain_alias
        string presentational_theme
        boolean paywall_enabled
    }
    DeliverySession {
        UUID id PK
        UUID portal_id FK
        string session_token
        string client_email
        int64 total_bytes
        boolean is_uploaded
    }
    DeliveryPaywall {
        UUID id PK
        UUID session_id FK
        int64 charge_amount_cents
        string stripe_payment_intent
        boolean is_paid
    }

    %% Classified Directory Extensions
    ListingBump {
        UUID id PK
        UUID listing_id FK
        datetime bumped_at
        int64 credits_spent
    }
    IdentityVerification {
        UUID id PK
        UUID profile_id FK
        string selfie_url
        string verification_status
        datetime verified_at
    }

    %% Property Management Entities
    LandlordPortfolio {
        UUID id PK
        UUID tenant_id FK
        string portfolio_name
    }
    ManagedProperty {
        UUID id PK
        UUID portfolio_id FK
        string street_address
        string building_type
        string tax_jurisdiction
    }
    LeaseContract {
        UUID id PK
        UUID property_id FK
        string tenant_name
        datetime start_date
        datetime end_date
        string btcpay_store_id
    }
    LateFeeSuppression {
        UUID id PK
        UUID lease_id FK
        int target_mempool_fee
        boolean is_suppressed
    }
    MaintenanceTriage {
        UUID id PK
        UUID property_id FK
        string emergency_code
        string description
        string status
    }

    %% Dynamic Packaging Entities
    PackageTenant {
        UUID id PK
        UUID tenant_id FK
        string subdomain
        string base_currency
    }
    AgencySeat {
        UUID id PK
        UUID tenant_id FK
        string email
        string agent_code
    }
    PackageBooking {
        UUID id PK
        UUID tenant_id FK
        UUID agent_id FK
        string customer_email
        int64 total_amount_cents
        string status
        string duffel_order_id
        string gds_pnr
    }
    BookingItem {
        UUID id PK
        UUID booking_id FK
        string type
        string provider_name
        string provider_reference
        int64 net_cost_cents
        int64 markup_cents
    }
    PriceLock {
        UUID id PK
        UUID booking_id FK
        string lock_token
        datetime expires_at
        int64 locked_total_cents
    }
    CommissionLedger {
        UUID id PK
        UUID booking_id FK
        int64 platform_fee_cents
        int64 agency_share_cents
        int64 hotel_payout_cents
    }

    %% STR Compliance Entities
    ComplianceProperty {
        UUID id PK
        UUID tenant_id FK
        string street_address
        string folio_number
        string zoning_classification
        string permittability_status
    }
    PropertyPermit {
        UUID id PK
        UUID property_id FK
        string type
        string permit_number
        datetime expiration_date
        string status
    }
    TdtBookingReceipt {
        UUID id PK
        UUID property_id FK
        string booking_platform
        int64 gross_rent_cents
        int64 tdt_collected_cents
        boolean tdt_remitted_by_platform
    }
    TdtMonthlyReconciliation {
        UUID id PK
        UUID property_id FK
        int filing_month
        int filing_year
        int64 total_tdt_owed_cents
        int64 platform_remitted_cents
        int64 host_liability_cents
        string filing_status
    }
    ActiveOtaListing {
        UUID id PK
        UUID property_id FK
        string platform
        string listing_url
        boolean active_status
    }
    ComplianceAlert {
        UUID id PK
        UUID property_id FK
        string severity
        string message
        boolean resolved
    }

    %% Direct Booking & Comms Entities
    BookingTenant {
        UUID id PK
        string domain_alias
        string pms_type
        string stripe_account_id
    }
    HotelRoomType {
        UUID id PK
        UUID tenant_id FK
        string name
        int64 base_price_cents
        int inventory_count
    }
    RoomRate {
        UUID id PK
        UUID room_type_id FK
        date rate_date
        int64 price_cents
        boolean gds_synced
    }
    CorporateContract {
        UUID id PK
        UUID tenant_id FK
        string company_name
        string access_code
        float discount_percent
        int room_block_allocation
    }
    DirectBooking {
        UUID id PK
        UUID tenant_id FK
        UUID corporate_contract_id FK
        string guest_email
        date check_in_date
        date check_out_date
        int64 total_amount_cents
        string status
    }
    BookedPerk {
        UUID id PK
        UUID booking_id FK
        string perk_type
        boolean redeemed
    }
    CartSession {
        UUID id PK
        UUID tenant_id FK
        string session_token
        string email_captured
        int recovery_phase
    }
    CommsTenant {
        UUID id PK
        string whatsapp_phone_number
        string twilio_sid
    }
    GuestProfile {
        UUID id PK
        UUID tenant_id FK
        string email
        string phone_number
        string detected_language
        string country_code
    }
    GuestReservation {
        UUID id PK
        UUID guest_profile_id FK
        string pms_reservation_code
        date check_in_date
        date check_out_date
        string reservation_status
    }
    MessageLog {
        UUID id PK
        UUID reservation_id FK
        string channel
        string direction
        string message_body
        string status
    }
    LocalRecommendation {
        UUID id PK
        UUID tenant_id FK
        string poi_name
        string category
        string language_code
        string description
        string target_demographics
    }
    RecipientStaff {
        UUID id PK
        UUID tenant_id FK
        string full_name
        string phone_number
        string role
        string native_language
    }
    WorkTask {
        UUID id PK
        UUID tenant_id FK
        UUID staff_id FK
        string task_description_english
        string task_description_translated
        string status
    }
