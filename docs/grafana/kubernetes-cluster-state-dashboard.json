{
  "dashboard": {
    "title": "Kubernetes Cluster State & Live Commits",
    "uid": "k8s-cluster-state",
    "tags": ["kubernetes", "state", "commits", "resources", "ingress"],
    "time": { "from": "now-6h", "to": "now" },
    "refresh": "1m",
    "panels": [
      {
        "id": 10,
        "title": "Total Cluster CPU Usage",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 4 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "fieldConfig": {
          "defaults": { "unit": "cores" }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\", container!=\"POD\"}[5m]))"
          }
        ]
      },
      {
        "id": 11,
        "title": "Total Cluster Memory Usage",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 4 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "fieldConfig": {
          "defaults": { "unit": "bytes" }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "expr": "sum(container_memory_working_set_bytes{container!=\"\", container!=\"POD\"})"
          }
        ]
      },
      {
        "id": 1,
        "title": "Pod Health Matrix",
        "type": "table",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 10 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "1": { "color": "green", "text": "Healthy (Running)" }, "0": { "color": "red", "text": "Unhealthy/Pending" } } }
            ]
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "expr": "kube_pod_status_phase{phase=\"Running\", exported_namespace=~\"atlas-.*\"}",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "labelsToFields",
            "options": {}
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": { "Time": true, "__name__": true, "container": true, "endpoint": true, "instance": true, "job": true, "namespace": true, "phase": true, "uid": true },
              "indexByName": { "exported_namespace": 0, "pod": 1, "Value": 2 },
              "renameByName": { "exported_namespace": "Environment", "pod": "Pod Name", "Value": "Status" }
            }
          }
        ]
      },
      {
        "id": 2,
        "title": "Live Version Matrix",
        "type": "table",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 10 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "expr": "max by(exported_namespace, exported_container, version) (label_replace(kube_pod_container_info{exported_namespace=~\"atlas-.*\", exported_container!=\"\", exported_container!=\"POD\"}, \"version\", \"$1\", \"image\", \".*:([^:]+)\"))",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "labelsToFields",
            "options": {}
          },
          {
            "id": "organize",
            "options": {
              "excludeByName": { "Time": true, "Value": true },
              "indexByName": { "exported_namespace": 0, "exported_container": 1, "version": 2 },
              "renameByName": { "exported_namespace": "Environment", "exported_container": "Service", "version": "Version / Commit" }
            }
          },
          {
            "id": "groupingToMatrix",
            "options": {
              "columnField": "Environment",
              "rowField": "Service",
              "valueField": "Version / Commit"
            }
          }
        ]
      },
      {
        "id": 3,
        "title": "CPU Usage per Pod",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"atlas-.*\", container!=\"\", container!=\"POD\"}[5m]))",
            "legendFormat": "{{pod}}"
          }
        ]
      },
      {
        "id": 4,
        "title": "Memory Usage per Pod",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"atlas-.*\", container!=\"\", container!=\"POD\"})",
            "legendFormat": "{{pod}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Ingress Errors (5xx)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "expr": "sum by (ingress) (rate(nginx_ingress_controller_requests{status=~\"5..\"}[5m]))",
            "legendFormat": "{{ingress}}"
          }
        ]
      },
      {
        "id": 6,
        "title": "OOMKills & Restarts",
        "type": "stat",
        "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "expr": "sum by (pod) (kube_pod_container_status_terminated_reason{reason=\"OOMKilled\"} > 0 or increase(kube_pod_container_status_restarts_total[1h]) > 0)",
            "legendFormat": "{{pod}} (Restarts/OOMs)"
          }
        ]
      }
    ]
  },
  "overwrite": true,
  "folderId": 0,
  "inputs": []
}
