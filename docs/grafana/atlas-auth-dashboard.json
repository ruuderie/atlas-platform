{
  "dashboard": {
    "title": "Atlas Platform — Auth, Passkeys & Frontend Health",
    "uid": "atlas-auth-v2",
    "tags": ["atlas", "auth", "passkeys", "frontend"],
    "time": { "from": "now-6h", "to": "now" },
    "panels": [
      {
        "title": "Magic Link Requests (per tenant)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(magic_link_requests_total[5m])",
            "legendFormat": "{{tenant_id}}"
          }
        ]
      },
      {
        "title": "Duplicate Magic Links Prevented",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(magic_link_duplicates_prevented_total)"
          }
        ]
      },
      {
        "title": "Auth Success Rate (5m)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(rate(auth_requests_total{status=\"success\"}[5m])) / clamp_max(sum(rate(auth_requests_total[5m])), 1)"
          }
        ]
      },
      {
        "title": "Auth Latency P95",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(auth_request_duration_seconds_bucket[5m])) by (le, action))"
          }
        ]
      },

      {
        "title": "Passkey Registration Funnel",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(passkey_registration_started_total[5m])",
            "legendFormat": "Started"
          },
          {
            "expr": "rate(passkey_registration_success_total[5m])",
            "legendFormat": "Completed"
          }
        ]
      },
      {
        "title": "Passkey Adoption Rate (7d)",
        "type": "stat",
        "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum(passkey_registration_success_total[7d]) / clamp_max(sum(passkey_registration_started_total[7d]), 1)"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        }
      },
      {
        "title": "Passkey Authentication Success Rate",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(passkey_auth_success_total[5m])"
          }
        ]
      },
      {
        "title": "Frontend Hydration Panics (Leptos)",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "rate(frontend_hydration_panics_total[5m])"
          }
        ]
      },
      {
        "title": "Auth Health Check Summary",
        "type": "stat",
        "gridPos": { "x": 0, "y": 32, "w": 24, "h": 6 },
        "targets": [
          {
            "expr": "auth_health_success_rate"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "center"
        }
      }
    ]
  }
}