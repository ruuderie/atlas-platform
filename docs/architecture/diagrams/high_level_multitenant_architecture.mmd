flowchart TB
    subgraph Clients ["Client Layer"]
        User[End Users / Tenant Visitors]
        Admin[Platform Administrators]
        Tenant_User[Tenant Sub-users]
    end

    subgraph Edge ["Routing & Proxy Tier"]
        Caddy[Caddy Reverse Proxy / K8s Ingress\nPreserves Host Header for Tenant Resolution]
    end

    subgraph Frontends ["Frontend Applications (Leptos)"]
        Anchor[Anchor CMS App\nSSR + WASM\napps/anchor]
        NetInst[Network Instance App\nSSR + WASM\napps/network-instance]
        PlatAdmin[Platform Admin Portal\nCSR\napps/platform-admin]
        FolioFE[Folio Property Management\nSSR + WASM\napps/folio — 9 role portals]
        SharedUI[shared-ui\n85 primitives + G-27 Configurator]
    end

    subgraph Backend ["Atlas API Backend (Rust Axum)"]
        subgraph AppRegistry ["AtlasApp Registry"]
            CoreApp[CorePlatformApp\nTier 1 — CMS base routes\nregistered FIRST]
            AnchorApp[AnchorApp\nTier 2 — Listings / CRM / Profiles]
            FolioBackend[Folio handlers/folio\nTier 2 — PM generics G09–G37]
        end

        subgraph Infra ["Platform Infrastructure (Tier 3 — api.rs)"]
            AuthRouter[Auth Routes\nMagic Links / Sessions / Validate]
            PasskeyRouter[Passkey / WebAuthn Routes]
            AdminRouter[Admin API Routes]
            RbacRouter[G-32 RBAC Routes]
        end

        subgraph Middleware ["Middleware Stack"]
            CorsReg[Dynamic CORS Registry\nper-domain allow-list]
            AppInst[AppInstance & Tenant\nResolution Middleware\nHost → tenant_id]
            ReqLog[Request Logger + Rate Limiter]
            ReqID[Request ID Middleware]
            VerHeader[X-Atlas-Version Header]
        end

        subgraph Workers ["Background Workers"]
            OutboxW[OutboxWorker\nSKIP LOCKED 1.5s]
            SyndBus[SyndicationEventBus\nG-05 HMAC delivery 10s]
            AIWorker[AITaskService::process_ai_tasks\nG-08 — admin pause/resume]
            DataSync[DataSyncService]
            Telemetry[TelemetryService\nHourly metrics]
            WebhookSweep[Webhook Sweeper]
        end

        subgraph Services ["Platform Generic Services"]
            AccountSvc[AccountService]
            ContactSvc[ContactService]
            LeadSvc[LeadService G31]
            ScoreSvc[ScorecardService G27]
            FlagSvc[FlagService]
            ProgSvc[ProgramService G36]
            AssetSvc[AssetService G10]
            ContractSvc[ContractService G11]
            CaseSvc[CaseService G13]
            OpptySvc[OpportunityService G15]
            LedgerSvc[LedgerService G03]
            DocSvc[DocumentService G14]
            SubSvc[SubscriptionService G04]
            RegSvc[RegulatoryRegService G16]
            TaxSvc[TaxService G17]
            AppSvc[ApplicationService G18]
            RealtimeSvc[RealtimeService G07]
            AITaskSvc[AITaskService G08]
            VaultSvc[VaultService G02]
            GeoSvc[GeoService G01]
            VerifSvc[VerificationService G06]
            IntegSvc[ExternalIntegrationService G05]
            PortfolioSvc[PortfolioService G09]
            SvcProvSvc[ServiceProviderService G12]
            NotifSvc[NotificationService G35]
            RbacSvc[RbacService G32]
        end

        WebAuthnReg[Multi-Tenant WebauthnRegistry\nMoka LRU Cache\neTLD+1 rp_id derivation]
        IngressProv[IngressProvisioner\nDynamic domain provisioning]
        PrometheusEndpoint[/metrics\nPrometheus scrape endpoint\nbearer-token protected]
    end

    subgraph DB ["Data & Storage Layer"]
        Postgres[(PostgreSQL\nShared Multi-Tenant DB\nRLS via tenant_id scoping)]
        MokaCache[(Moka In-Memory Cache\nAppInstance / WebAuthn)]
        R2[Cloudflare R2\nObject Storage\nLease PDFs / Media / Vault]
    end

    subgraph ExtSvc ["External Services"]
        SMTP[SMTP Email Gateway]
        Mempool[mempool.space API\nBTC TX validation]
        Stripe[Stripe\nPayment Rails]
        Twilio[Telephony / SMS]
        PMS_OTA[PMS / OTA / AMS\nExternal Integrations G05]
    end

    %% Client routing
    User -->|Visits tenant domain| Caddy
    Admin -->|admin.domain.com| Caddy
    Tenant_User -->|Visits app subdomain| Caddy

    %% Caddy to frontends
    Caddy -->|SSR / WASM| Anchor
    Caddy -->|SSR / WASM| NetInst
    Caddy -->|SSR / WASM| FolioFE
    Caddy -->|CSR Assets| PlatAdmin
    FolioFE -.->|uses| SharedUI
    Anchor -.->|uses| SharedUI
    NetInst -.->|uses| SharedUI
    PlatAdmin -.->|uses| SharedUI

    %% Frontend to backend API
    Anchor -->|API request + Host header| AppInst
    NetInst -->|API request + Host header| AppInst
    FolioFE -->|API request + Host header| AppInst
    PlatAdmin -->|API request + tenant_id| AdminRouter

    %% Middleware chain
    AppInst -->|Cache lookup| MokaCache
    AppInst -->|Verify tenant| Postgres
    AppInst --> CoreApp
    AppInst --> AnchorApp
    AppInst --> FolioBackend

    %% Services → DB
    Services --> Postgres
    Services -->|File upload| R2

    %% Workers → DB/External
    OutboxW --> Postgres
    OutboxW --> SMTP
    SyndBus --> Postgres
    SyndBus --> PMS_OTA
    AIWorker --> Postgres
    DataSync --> Postgres
    DataSync --> Mempool
    Telemetry --> Postgres
    WebhookSweep --> Postgres

    %% WebAuthn
    PasskeyRouter --> WebAuthnReg
    WebAuthnReg -->|DoS check| Postgres
    WebAuthnReg -->|Cache instance| MokaCache

    %% Payment external services
    LedgerSvc --> Stripe
    DataSync --> Mempool

    %% Integrations
    IntegSvc --> PMS_OTA
    Workers --> Twilio
