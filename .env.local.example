# Local-only overrides for Docker Compose + atlas-local.
# Copied to .env.local on first `atlas-local up` (gitignored).
# Never commit real secrets here. Do NOT deploy these values to K8s.

ENVIRONMENT=development

# Browser-facing URLs (Caddy *.localhost)
ADMIN_URL=http://admin.localhost
FRONTEND_URL=http://directory.network.localhost
BROWSER_API_URL=http://api.localhost
PUBLIC_API_BASE_URL=http://api.localhost

# Isolated local WebAuthn — separate from server RP_ID (atlas.oply.co).
# Register a NEW local passkey; server passkeys will not work here.
WEBAUTHN_ORIGIN=http://admin.localhost
RP_ID=localhost

ADDITIONAL_ALLOWED_ORIGINS=http://admin.localhost,http://api.localhost,http://directory.network.localhost,http://folio.localhost,http://anchor.localhost,http://buildwithruud.localhost,http://oplystusa.localhost,http://ruuderie.localhost,http://localhost:3000,http://localhost:3100,http://localhost:8080,http://localhost:8081

# Optional: remote DB URLs for `atlas-local db pull --from …`
# ATLAS_DEV_DATABASE_URL=postgresql://user:pass@host:5432/atlas_dev
# ATLAS_UAT_DATABASE_URL=postgresql://user:pass@host:5432/atlas_uat
# ATLAS_PROD_DATABASE_URL=postgresql://user:pass@host:5432/atlas_prod
